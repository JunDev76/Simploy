{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JunDev76/Simploy/main/dist/schema.json",
  "title": "Simploy Config",
  "description": "Configuration file for Simploy - a simple SSH-based deployment tool. See https://github.com/JunDev76/Simploy",
  "type": "object",
  "required": ["environments"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URI for validation and IDE autocomplete"
    },
    "environments": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["servers"],
        "properties": {
          "servers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "ssh", "localPath", "remotePath"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Server name (used in logs and --server filter)"
                },
                "ssh": {
                  "type": "object",
                  "required": ["host", "username"],
                  "properties": {
                    "host": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Server hostname or IP"
                    },
                    "port": {
                      "oneOf": [
                        { "type": "integer", "minimum": 1, "maximum": 65535 },
                        { "type": "string", "minLength": 1 }
                      ],
                      "default": 22,
                      "description": "SSH port (number or ${VAR} string for variable substitution)"
                    },
                    "username": {
                      "type": "string",
                      "minLength": 1,
                      "description": "SSH username"
                    },
                    "password": {
                      "type": "string",
                      "description": "SSH password (use secrets file for sensitive values)"
                    },
                    "privateKeyPath": {
                      "type": "string",
                      "description": "Path to SSH private key (e.g. ~/.ssh/id_rsa)"
                    },
                    "passphrase": {
                      "type": "string",
                      "description": "Passphrase for private key"
                    }
                  },
                  "description": "SSH connection config. Either password or privateKeyPath is required."
                },
                "localPath": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Local directory to deploy (relative to cwd)"
                },
                "remotePath": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Remote directory to deploy to"
                },
                "exclude": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Files/dirs to exclude from upload. node_modules, .git, simploy.json, simploy.secrets.json are always excluded."
                },
                "preserve": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Remote files to preserve during cleanup. If empty, rm -rf remotePath/* is used."
                },
                "preDeploy": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Shell commands run before file transfer (e.g. stop services)"
                },
                "postDeploy": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Shell commands run after file transfer (e.g. npm ci, npm start)"
                }
              }
            }
          },
          "variables": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Key-value pairs for ${VAR} substitution in config values"
          }
        }
      }
    }
  }
}